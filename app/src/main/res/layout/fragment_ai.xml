<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_primary" android:orientation="vertical">
    <TextView android:layout_width="match_parent" android:layout_height="56dp"
        android:text="🤖 NeoX AI Assistant" android:textColor="@color/neon_cyan"
        android:fontFamily="monospace" android:textSize="16sp" android:gravity="center_vertical"
        android:paddingStart="16dp" android:background="@color/bg_secondary"/>
    <ScrollView android:id="@+id/chat_scroll"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="12dp">
        <LinearLayout android:id="@+id/chat_container"
            android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
    </ScrollView>
    <ProgressBar android:id="@+id/loading_indicator"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" android:indeterminateTint="@color/neon_green"
        android:visibility="gone"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@color/bg_input" android:gravity="center_vertical"
        android:paddingStart="12dp" android:paddingEnd="12dp" android:orientation="horizontal">
        <EditText android:id="@+id/input_field"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:background="@null" android:hint="@string/ai_placeholder"
            android:hintTextColor="@color/text_dim" android:textColor="@color/text_primary"
            android:fontFamily="monospace" android:textSize="13sp" android:imeOptions="actionSend"/>
        <Button android:id="@+id/btn_send" style="@style/NeoButton"
            android:layout_width="wrap_content" android:layout_height="40dp" android:text="ASK"/>
    </LinearLayout>
</LinearLayout>
