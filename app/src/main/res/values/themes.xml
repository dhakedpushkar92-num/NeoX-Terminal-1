<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NeoXTerminal" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_green</item>
        <item name="colorPrimaryDark">@color/bg_primary</item>
        <item name="colorAccent">@color/neon_purple</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_secondary</item>
    </style>
    <style name="NeoButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/neon_green</item>
        <item name="strokeColor">@color/neon_green</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="ExtraKey" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:textSize">11sp</item>
        <item name="android:minWidth">40dp</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>
